NEXTAUTH_SECRET=genera-con-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
ADMIN_USER=tu-usuario
ADMIN_PASSWORD=tu-contraseña
OMDB_API_KEY=tu-omdb-key
DATABASE_URL=file:./dev.db

# Turso — base de datos en producción (Vercel)
# turso db show <nombre>  →  TURSO_DATABASE_URL
# turso db tokens create <nombre>  →  TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=tu-token

# Cloudinary — server-side (Settings > API Keys en Cloudinary Console)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_UPLOAD_PRESET=directors_cut
CLOUDINARY_TAG=pelicula
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# Cloudinary — client-side
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=directors_cut
NEXT_PUBLIC_CLOUDINARY_TAG=pelicula
